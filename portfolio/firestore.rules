// firestore.rules
// ──────────────────────────────────────────────────────────────
// Security rules for the portfolio contact form.
//
// The "messages" collection:
//   - Anyone can CREATE (submit the contact form)
//   - Nobody can READ, UPDATE, or DELETE from the client side
//   - Cloud Functions run with admin privileges and bypass these rules
//   - Validates required fields and enforces size limits
// ──────────────────────────────────────────────────────────────

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Contact form messages
    match /messages/{messageId} {

      // Allow anyone to create a message (contact form submission)
      allow create: if
        // Must have all required fields
        request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt', 'read', 'source'])
        // Field type validation
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.subject is string
        && request.resource.data.message is string
        && request.resource.data.read is bool
        && request.resource.data.source is string
        // Length limits (prevent abuse)
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && request.resource.data.email.size() >= 5
        && request.resource.data.email.size() <= 200
        && request.resource.data.subject.size() >= 3
        && request.resource.data.subject.size() <= 200
        && request.resource.data.message.size() >= 10
        && request.resource.data.message.size() <= 2000
        // Prevent client from setting read to true
        && request.resource.data.read == false;

      // No reading, updating, or deleting from client
      allow read, update, delete: if false;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
